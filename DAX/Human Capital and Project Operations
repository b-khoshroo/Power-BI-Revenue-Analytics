/* --- EMPLOYEE PARTICIPATION RATE (LAST 2 YEARS) ---
Calculates the percentage of the total workforce actively assigned to projects within a rolling 24-month window. This metric is used to evaluate human capital utilization and track historical engagement trends against the total headcount.
*/

Employee Participation Rate (Last 2 Years) = 
VAR dateTwoYearsAgo = DATE(YEAR(TODAY())-2, MONTH(TODAY()), DAY(TODAY()))
VAR activeEmployeeLastTwoYears = CALCULATE(DISTINCTCOUNT(BridgeEmployeeProject[Employee ID]), Projects[End Date] >= dateTwoYearsAgo )
VAR allEmployee = DISTINCTCOUNT(Employee[Employee ID])
RETURN
    DIVIDE(activeEmployeeLastTwoYears, allEmployee, 0)

